{
  "name": "Anti-AI + Anti-ISP-Snooping Blocklist",
  "description": "Auto-updated every 15 min. Blocks AI platform endpoints, ISP tracking/ad-injection domains, telemetry collectors, and training data harvesters. Includes firewall rules that force all DNS through trusted resolvers (Cloudflare/Quad9/Google/NextDNS), blocking ISP DNS interception, NXDOMAIN hijacking, and query logging. Sources: crt.sh CT logs, Hagezi Pro, v2fly, MoralCode antitelemetry, seed list. Updated: 2026-06-26 01:23 UTC | Domains: 176",
  "rules": [
    {
      "action": "allow",
      "process": "any",
      "remote-addresses": "1.1.1.1, 1.0.0.1, 2606:4700:4700::1111, 2606:4700:4700::1001, 9.9.9.9, 149.112.112.112, 8.8.8.8, 8.8.4.4, 45.90.28.0, 45.90.30.0",
      "ports": "53, 853",
      "protocol": "udp,tcp",
      "direction": "outgoing",
      "notes": "Allow DNS/DoT to trusted resolvers only (Cloudflare, Quad9, Google, NextDNS)"
    },
    {
      "action": "deny",
      "process": "any",
      "remote": "any",
      "ports": "53, 853",
      "protocol": "udp,tcp",
      "direction": "outgoing",
      "notes": "Block DNS to all other hosts \u2014 prevents ISP resolver interception, query logging, NXDOMAIN hijacking, and ad injection via DNS"
    }
  ],
